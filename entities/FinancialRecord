    "data_vencimento": {
      "type": "string",
      "format": "date"
    },
    "data_pagamento": {
      "type": "string",
      "format": "date"
    },
    "forma_pagamento": {
      "type": "string",
      "enum": [
        "Dinheiro",
        "PIX",
        "Cart\u00e3o de Cr\u00e9dito",
        "Cart\u00e3o de D\u00e9bito",
        "Transfer\u00eancia",
        "Outro"
      ]
    },
