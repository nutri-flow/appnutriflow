{
  "name": "FinancialRecord",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID da organiza\u00e7\u00e3o"
    },
    "patient_id": {
      "type": "string"
    },
    "consultation_id": {
      "type": "string"
    },
    "descricao": {
      "type": "string"
    },
    "valor": {
      "type": "number"
    },
